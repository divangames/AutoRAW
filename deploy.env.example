# Скопируйте в deploy.env (файл в .gitignore) для выгрузки по SSH.
# Если deploy.env нет — deploy.ps1 делает git push (GitHub Pages).

SSH_HOST=your.server.example
SSH_USER=root
SSH_PORT=22
REMOTE_PATH=/var/www/autoraw-presentation
# SSH_KEY=C:\Users\you\.ssh\id_ed25519
# PUBLIC_URL=https://your.server.example/autoraw/
