<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RepoRoot>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\..\..\'))</RepoRoot>
    <!-- Version = первые 4 компонента из CHANGELOG; InformationalVersion = все 5 (см. bat/Resolve-VersionFromChangelog.ps1). -->
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationTitle>AutoRAW</ApplicationTitle>
    <RootNamespace>AutoRAW</RootNamespace>
    <AssemblyName>AutoRAW</AssemblyName>
    <LangVersion>latest</LangVersion>
    <ApplicationIcon>..\..\assets\images\favicon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Markdig" Version="0.41.3" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Emoji.Wpf" Version="0.3.4" />
    <PackageReference Include="Magick.NET-Q16-AnyCPU" Version="14.7.0" />
    <PackageReference Include="OpenCvSharp4" Version="4.10.0.20240616" />
    <PackageReference Include="OpenCvSharp4.runtime.win" Version="4.10.0.20240616" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\Instruction.md" Link="Instruction.md" CopyToOutputDirectory="PreserveNewest" />
    <Resource Include="..\..\assets\images\favicon.ico" Link="Assets\favicon.ico" />
    <Resource Include="..\..\assets\images\SplashScreen.png" Link="Assets\SplashScreen.png" />
    <Resource Include="..\..\assets\images\ava_z.png" Link="Assets\ava_z.png" />
    <Content Include="..\..\CHANGELOG.md" Link="CHANGELOG.md" CopyToOutputDirectory="PreserveNewest" Condition="Exists('..\..\CHANGELOG.md')" />
  </ItemGroup>

  <Target Name="ResolveVersionFromChangelog" BeforeTargets="PrepareForBuild;GetAssemblyVersion;GenerateAssemblyInfo;CoreGenerateAssemblyInfo">
    <PropertyGroup>
      <_Changelog>$(RepoRoot)CHANGELOG.md</_Changelog>
      <_ResolveScript>$(RepoRoot)bat\Resolve-VersionFromChangelog.ps1</_ResolveScript>
      <_VersionAsm>$(MSBuildProjectDirectory)\obj\changelog_version_assembly.txt</_VersionAsm>
      <_VersionInfo>$(MSBuildProjectDirectory)\obj\changelog_version_info.txt</_VersionInfo>
    </PropertyGroup>
    <MakeDir Directories="$(MSBuildProjectDirectory)\obj" Condition="!Exists('$(MSBuildProjectDirectory)\obj')" />
    <PropertyGroup Condition="!Exists('$(_Changelog)')">
      <Version>0.0.0</Version>
      <FileVersion>0.0.0</FileVersion>
      <InformationalVersion>0.0.0.0.0</InformationalVersion>
    </PropertyGroup>
    <Exec Condition="Exists('$(_Changelog)')"
          Command="powershell.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;$(_ResolveScript)&quot; -ChangelogPath &quot;$(_Changelog)&quot; -OutAssemblyVersionFile &quot;$(_VersionAsm)&quot; -OutInformationalVersionFile &quot;$(_VersionInfo)&quot;"
          LogStandardErrorAsError="true"
          WorkingDirectory="$(RepoRoot)" />
    <ReadLinesFromFile File="$(_VersionAsm)" Condition="Exists('$(_Changelog)') And Exists('$(_VersionAsm)')">
      <Output TaskParameter="Lines" ItemName="_ChangelogAsmLine" />
    </ReadLinesFromFile>
    <ReadLinesFromFile File="$(_VersionInfo)" Condition="Exists('$(_Changelog)') And Exists('$(_VersionInfo)')">
      <Output TaskParameter="Lines" ItemName="_ChangelogInfoLine" />
    </ReadLinesFromFile>
    <PropertyGroup Condition="Exists('$(_Changelog)') And '@(_ChangelogAsmLine)' != ''">
      <Version>@(_ChangelogAsmLine)</Version>
      <FileVersion>@(_ChangelogAsmLine)</FileVersion>
    </PropertyGroup>
    <PropertyGroup Condition="Exists('$(_Changelog)') And '@(_ChangelogInfoLine)' != ''">
      <InformationalVersion>@(_ChangelogInfoLine)</InformationalVersion>
    </PropertyGroup>
  </Target>

  <Target Name="CopyRepoReferenceZona" AfterTargets="Build">
    <ItemGroup>
      <_Ref     Include="$(RepoRoot)reference\**\*.*" Condition="Exists('$(RepoRoot)reference')" />
      <_Zona    Include="$(RepoRoot)zona\**\*.*"      Condition="Exists('$(RepoRoot)zona')" />
      <_Setting Include="$(RepoRoot)setting\**\*.*"   Condition="Exists('$(RepoRoot)setting')" />
      <_Profiles Include="$(RepoRoot)profiles\**\*.*" Condition="Exists('$(RepoRoot)profiles')" />
    </ItemGroup>
    <Copy SourceFiles="@(_Ref)"     DestinationFiles="$(OutDir)reference\%(_Ref.RecursiveDir)%(Filename)%(Extension)"   SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_Zona)"    DestinationFiles="$(OutDir)zona\%(_Zona.RecursiveDir)%(Filename)%(Extension)"        SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_Setting)" DestinationFiles="$(OutDir)setting\%(_Setting.RecursiveDir)%(Filename)%(Extension)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_Profiles)" DestinationFiles="$(OutDir)profiles\%(_Profiles.RecursiveDir)%(Filename)%(Extension)" SkipUnchangedFiles="true" />
  </Target>

</Project>
