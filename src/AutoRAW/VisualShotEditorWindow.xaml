<Window x:Class="AutoRAW.VisualShotEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AutoRAW.ViewModels"
        xmlns:controls="clr-namespace:AutoRAW.Controls"
        mc:Ignorable="d"
        x:Name="Root"
        Title="Редактор положения кадра"
        Width="960"
        Height="700"
        MinWidth="800"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.WindowBg}"
        FontFamily="Segoe UI"
        FontSize="12">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <!-- Контрастнее обычного Secondary на тёмном фоне редактора -->
    <Style x:Key="VisualEditorToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
      <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Theme.BorderActive}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="EditorIconButtonStyle" TargetType="Button" BasedOn="{StaticResource VisualEditorToolbarButtonStyle}">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Window.Resources>
  <DockPanel Background="{DynamicResource Theme.WindowBg}">
    <Menu DockPanel.Dock="Top"
          Background="{DynamicResource Theme.MenuBarBg}"
          Padding="4,2">
      <MenuItem Header="Файл">
          <MenuItem Header="Применить профиль">
          <MenuItem Header="Только для этой фотографии"
                    Command="{Binding PersistAdjustmentsForCurrentFileCommand}" />
          <MenuItem Header="{Binding SameFileNameMenuHeader}"
                    Command="{Binding ApplyAdjustmentsToSameFileNameCommand}" />
          <MenuItem Header="Убрать правило профиля по имени текущего файла"
                    Command="{Binding ClearProfileBasenameRuleCommand}" />
          <MenuItem Header="Сохранить как профиль…"
                    Command="{Binding SaveAsNewProfileCommand}" />
        </MenuItem>
        <Separator />
        <MenuItem Header="Сохранить для профиля (текущий кадр)"
                  Command="{Binding SaveStemForProfileCommand}" />
      </MenuItem>
    </Menu>

    <TextBlock DockPanel.Dock="Top"
               Margin="12,8,12,0"
               FontSize="11"
               TextWrapping="Wrap"
               Foreground="{DynamicResource Theme.TextSubtle}">
      Папки из «Товар» → файлы → кадр под размер референса. Сетка только на превью.
    </TextBlock>

    <Grid Margin="12,8,12,12">
          <Grid Visibility="{Binding IsBrowseMode, Converter={StaticResource BoolToVis}}"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="168" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" Margin="0,0,10,0" LastChildFill="True">
              <TextBlock DockPanel.Dock="Top"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource Theme.TextPrimary}"
                         Text="Папка"
                         Margin="0,0,0,6" />
              <StackPanel DockPanel.Dock="Top"
                          Orientation="Horizontal"
                          Margin="0,0,0,6">
                <Button Style="{StaticResource EditorIconButtonStyle}"
                        Content="&#xE76D;"
                        Command="{Binding IgnoreSelectedFolderCommand}"
                        ToolTip="Пропустить: исключить выбранные подпапки из очереди (Ctrl — несколько)" />
                <Button Style="{StaticResource EditorIconButtonStyle}"
                        Margin="4,0,0,0"
                        Content="&#xE777;"
                        Command="{Binding RestoreSelectedFolderCommand}"
                        ToolTip="Вернуть выбранные подпапки в очередь" />
              </StackPanel>
              <TreeView x:Name="FoldersTree"
                        DockPanel.Dock="Bottom"
                        ItemsSource="{Binding FolderTreeRoots}"
                        SelectedItemChanged="FoldersTree_SelectedItemChanged"
                        BorderBrush="{DynamicResource Theme.DialogBorder}"
                        Background="{DynamicResource Theme.DialogBg}"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                <TreeView.ItemTemplate>
                  <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding ListLabel}"
                               Foreground="{DynamicResource Theme.TextPrimary}"
                               FontSize="12" />
                  </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </DockPanel>
            <DockPanel Grid.Column="1" LastChildFill="True">
              <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6" LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Theme.TextPrimary}"
                           Text="Файлы" />
                <WrapPanel DockPanel.Dock="Top" Margin="0,6,0,4">
                  <TextBlock VerticalAlignment="Center" Margin="0,0,8,4" Foreground="{DynamicResource Theme.TextBody}"
                             Text="Показать:" />
                  <ComboBox Width="188"
                            Margin="0,0,12,4"
                            VerticalAlignment="Center"
                            ItemsSource="{Binding BrowseFilterOptions}"
                            DisplayMemberPath="Display"
                            SelectedValuePath="Kind"
                            SelectedValue="{Binding BrowseFilterKind, Mode=TwoWay}" />
                  <TextBox Width="120"
                           Margin="0,0,12,4"
                           VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Height="26"
                           ToolTip="Номер кадра: 1, 2, 01… или часть имени файла"
                           Text="{Binding BrowseFilterText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                      <Style TargetType="TextBox">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding BrowseFilterKind}" Value="{x:Static vm:EditorBrowseFilterKind.FilterByShotOrName}">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBox.Style>
                  </TextBox>
                  <CheckBox VerticalAlignment="Center"
                            Margin="0,0,0,4"
                            Content="Группировать по имени файла"
                            IsChecked="{Binding BrowseGroupByFileName, Mode=TwoWay}" />
                </WrapPanel>
              </DockPanel>
              <ListBox x:Name="FilesList"
                       DockPanel.Dock="Bottom"
                       ItemsSource="{Binding FilesView}"
                       SelectionMode="Extended"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       BorderThickness="0"
                       Background="Transparent"
                       Padding="0"
                       VerticalAlignment="Stretch">
                <ListBox.GroupStyle>
                  <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                      <DataTemplate>
                        <TextBlock Margin="0,10,0,4"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.TextPrimary}"
                                   Text="{Binding Name}" />
                      </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                  </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                  <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="4" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Top" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                          <Border x:Name="Outer"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="Transparent"
                                  BorderThickness="1"
                                  CornerRadius="4"
                                  Padding="{TemplateBinding Padding}"
                                  SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                              <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource Theme.BorderActive}" />
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Width="116">
                      <!-- Превью в пропорции выходного кадра 1400×1050 -->
                      <Border Width="108"
                              Height="81"
                              BorderBrush="{DynamicResource Theme.DialogBorder}"
                              BorderThickness="1"
                              CornerRadius="4"
                              Background="{DynamicResource Theme.DialogBg}"
                              Cursor="Hand"
                              ClipToBounds="True"
                              MouseLeftButtonUp="Thumb_OnMouseLeftButtonUp">
                        <Border.ToolTip>
                          <TextBlock Text="{Binding FilePath}" TextWrapping="Wrap" MaxWidth="360" />
                        </Border.ToolTip>
                        <Grid>
                          <Image Source="{Binding Thumbnail}"
                                 Stretch="UniformToFill"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                          <controls:BusySpinner HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsThumbLoading, Converter={StaticResource BoolToVis}}" />
                          <Border Background="#AA000000"
                                  VerticalAlignment="Bottom"
                                  Opacity="0">
                            <Border.Style>
                              <Style TargetType="Border">
                                <Style.Triggers>
                                  <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                  </Trigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                            <TextBlock Text="Открыть"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,4"
                                       FontWeight="SemiBold" />
                          </Border>
                        </Grid>
                      </Border>
                      <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0"
                                  ToolTip="Включить файл в очередь пакетной обработки (с Ctrl можно выделить несколько строк)" />
                        <Grid Width="84">
                          <TextBlock VerticalAlignment="Center"
                                     Foreground="{DynamicResource Theme.TextBody}"
                                     FontSize="11"
                                     TextTrimming="CharacterEllipsis"
                                     ToolTip="{Binding FilePath}"
                                     Text="{Binding FileLabel}"
                                     PreviewMouseLeftButtonDown="FileName_OnPreviewMouseLeftButtonDown">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                          <TextBox Height="22"
                                   FontSize="11"
                                   VerticalContentAlignment="Center"
                                   Text="{Binding RenameDraft, UpdateSourceTrigger=PropertyChanged}"
                                   Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}"
                                   Loaded="RenameBox_Loaded"
                                   LostFocus="RenameBox_LostFocus"
                                   KeyDown="RenameBox_KeyDown" />
                        </Grid>
                      </StackPanel>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Grid>

          <Grid VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch">
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsBrowseMode}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
              <Button DockPanel.Dock="Left"
                      Content="← К списку файлов"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Padding="10,6"
                      Margin="0,0,12,0"
                      Command="{Binding BackToBrowseCommand}" />
              <TextBlock VerticalAlignment="Center"
                         Foreground="{DynamicResource Theme.TextBody}"
                         TextTrimming="CharacterEllipsis">
                <Run Text="Файл: " />
                <Run Text="{Binding EditorInputPath, Mode=OneWay}" FontWeight="SemiBold" />
              </TextBlock>
            </DockPanel>

            <Grid Grid.Row="1" VerticalAlignment="Stretch">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="272" />
              </Grid.ColumnDefinitions>

              <DockPanel Grid.Column="0" Margin="0,0,10,0" LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource Theme.TextPrimary}"
                           Text="Результат (тащите — смещение X/Y, px выхода)" />
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource Theme.DialogBorder}"
                        BorderThickness="1"
                        Background="#202020"
                        CornerRadius="4"
                        ClipToBounds="True"
                        MinHeight="200"
                        VerticalAlignment="Stretch">
                  <Grid>
                    <Image x:Name="ResultImage"
                           Source="{Binding ResultPreview}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MouseLeftButtonDown="ResultImage_OnMouseLeftButtonDown"
                           MouseMove="ResultImage_OnMouseMove"
                           MouseLeftButtonUp="ResultImage_OnMouseLeftButtonUp"
                           MouseLeave="ResultImage_OnMouseLeave" />
                    <controls:BusySpinner HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding IsEditorLargePreviewBusy, Converter={StaticResource BoolToVis}}" />
                  </Grid>
                </Border>
              </DockPanel>

              <DockPanel Grid.Column="1" LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource Theme.TextPrimary}"
                           Text="Референс" />
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource Theme.DialogBorder}"
                        BorderThickness="1"
                        Height="160"
                        CornerRadius="4"
                        Margin="0,0,0,10">
                  <Grid>
                    <Image Source="{Binding ReferencePreview}" Stretch="Uniform" />
                    <controls:BusySpinner HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding IsEditorLargePreviewBusy, Converter={StaticResource BoolToVis}}" />
                  </Grid>
                </Border>

                <ScrollViewer DockPanel.Dock="Bottom"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,0,4">
                  <TextBlock Text="Номер кадра (референс / Zona)" Margin="0,0,0,4" Foreground="{DynamicResource Theme.TextBody}" />
                  <ComboBox ItemsSource="{Binding ShotStemChoices}"
                            SelectedItem="{Binding SelectedShotStem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            MinHeight="28"
                            Margin="0,0,0,12" />
                  <TextBlock Text="Смещение X (px)" Foreground="{DynamicResource Theme.TextBody}" />
                  <TextBox Text="{Binding OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8" />

                  <TextBlock Text="Смещение Y (px)" Foreground="{DynamicResource Theme.TextBody}" />
                  <TextBox Text="{Binding OffsetY, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8" />

                  <TextBlock Text="Масштаб (%)" Foreground="{DynamicResource Theme.TextBody}" />
                  <TextBox Text="{Binding ZoomPercent, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8" />

                  <TextBlock Text="Поворот (°)" Foreground="{DynamicResource Theme.TextBody}" />
                  <TextBox Text="{Binding RotationDeg, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8" />

                  <TextBlock Text="Сетка выравнивания (только превью)" Foreground="{DynamicResource Theme.TextBody}" />
                  <ComboBox ItemsSource="{Binding GridOverlayOptions}"
                            DisplayMemberPath="Display"
                            SelectedValuePath="Kind"
                            SelectedValue="{Binding GridOverlay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            MinHeight="28"
                            Margin="0,2,0,12" />

                  <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Style="{StaticResource EditorIconButtonStyle}"
                            Content="&#xE7A7;"
                            ToolTip="Отменить (Ctrl+Z)"
                            Command="{Binding UndoAdjustCommand}" />
                    <Button Style="{StaticResource EditorIconButtonStyle}"
                            Margin="4,0,0,0"
                            Content="&#xE7A6;"
                            ToolTip="Повтор (Ctrl+Y)"
                            Command="{Binding RedoAdjustCommand}" />
                    <Button Style="{StaticResource EditorIconButtonStyle}"
                            Margin="4,0,0,0"
                            Content="&#xE9D9;"
                            ToolTip="Авто-подгонка: макет 1400×1050, safe zone; YOLOv8/U2Net/OpenCV"
                            Command="{Binding RunAutoAlignCommand}" />
                  </StackPanel>
                  <Button Content="Применить изменения"
                          Margin="0,0,0,6"
                          Style="{StaticResource PrimaryActionButtonStyle}"
                          Padding="12,8"
                          ToolTip="Сохранить текущие правки только для этого файла"
                          Command="{Binding PersistAdjustmentsForCurrentFileCommand}" />
                  <Button Content="Сбросить"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Padding="12,8"
                          ToolTip="Удалить сохранённые правки для этого файла"
                          Command="{Binding ResetAdjustmentsCommand}" />
                </StackPanel>
                </ScrollViewer>
              </DockPanel>
            </Grid>

            <TextBlock Grid.Row="2"
                       Margin="0,8,0,0"
                       Text="{Binding StatusText}"
                       Foreground="{DynamicResource Theme.Accent}"
                       TextWrapping="Wrap" />
          </Grid>
    </Grid>
  </DockPanel>
</Window>
