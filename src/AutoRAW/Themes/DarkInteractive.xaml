<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- SystemColors — в тон палитре ТЗ (#1E1E1E / #252526 / #2D2D30 / #0078D4) -->
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#252526" />
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#252526" />
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#F0F0F0" />
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#3C3C3C" />
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D30" />
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#F0F0F0" />

  <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#3C3C3C" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F0F0F0" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#404040" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#484848" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#2D2D30" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#1E1E1E" />

  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#264F78" />
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F0F0F0" />
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3C3C3C" />
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#A0A0A0" />

  <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#808080" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ScrollBarBrushKey}" Color="#686868" />
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveCaptionBrushKey}" Color="#252526" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ActiveCaptionBrushKey}" Color="#252526" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ActiveCaptionTextBrushKey}" Color="#F0F0F0" />

  <Style TargetType="Control">
    <Setter Property="FontFamily" Value="Segoe UI" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
  </Style>

  <!-- Прозрачные повторы для трека слайдера -->
  <Style x:Key="FluentSliderRepeatButton" TargetType="RepeatButton">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Rectangle Fill="Transparent" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="Menu">
    <Setter Property="Foreground" Value="{DynamicResource Theme.TextBody}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <!-- MenuItem: свой Popup — иначе Aero оставляет белую рамку выпадающего списка -->
  <Style TargetType="MenuItem">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.TextBody}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="MenuItem">
          <Grid SnapsToDevicePixels="True">
            <Border x:Name="ItemBorder"
                    Background="{TemplateBinding Background}"
                    BorderThickness="0"
                    Padding="{TemplateBinding Padding}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ContentPresenter Grid.Column="0"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True"
                                    VerticalAlignment="Center" />
                <Path x:Name="GlyphPanel"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      Margin="12,0,4,0"
                      Visibility="Collapsed"
                      Fill="{TemplateBinding Foreground}"
                      Data="M 0,0 L 4,4 L 0,8 Z" />
              </Grid>
            </Border>
            <Popup x:Name="PART_Popup"
                   AllowsTransparency="True"
                   Focusable="False"
                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                   PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                   Placement="Right"
                   HorizontalOffset="0"
                   VerticalOffset="0">
              <Border Background="{DynamicResource Theme.MenuPopupBg}"
                      BorderBrush="{DynamicResource Theme.MenuPopupBorder}"
                      BorderThickness="1"
                      CornerRadius="2"
                      Padding="2"
                      SnapsToDevicePixels="True">
                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
              </Border>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.ListItemHover}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource Theme.TextHint}" />
            </Trigger>
            <Trigger Property="Role" Value="TopLevelHeader">
              <Setter Property="Padding" Value="8,6" />
              <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
              <Setter TargetName="GlyphPanel" Property="Visibility" Value="Collapsed" />
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
              <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
              <Setter TargetName="GlyphPanel" Property="Visibility" Value="Visible" />
              <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
            </Trigger>
            <Trigger Property="HasItems" Value="False">
              <Setter TargetName="GlyphPanel" Property="Visibility" Value="Collapsed" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="Separator">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Margin" Value="8,4" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Separator">
          <Border Height="1"
                  Background="{DynamicResource Theme.MenuBarBorder}"
                  SnapsToDevicePixels="True" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ContextMenu">
    <Setter Property="Background" Value="{DynamicResource Theme.MenuPopupBg}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.TextBody}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.MenuPopupBorder}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style TargetType="ToolTip">
    <Setter Property="Background" Value="{DynamicResource Theme.MenuPopupBg}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.TextBody}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.MenuPopupBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="8,6" />
  </Style>

  <Style TargetType="ListBox">
    <Setter Property="Background" Value="{DynamicResource Theme.ListSurface}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.ListBorder}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style TargetType="ListBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
    <Setter Property="Padding" Value="6,4" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource Theme.ListItemHover}" />
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource Theme.ListItemSelected}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
    <Setter Property="Background" Value="Transparent" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource Theme.ListItemHover}" />
      </Trigger>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="{DynamicResource Theme.ListItemSelected}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource Theme.TextBody}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Padding" Value="4,0,0,0" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal" SnapsToDevicePixels="True">
            <Border x:Name="Box"
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Theme.InputBackground}"
                    BorderBrush="{DynamicResource Theme.InputBorder}"
                    BorderThickness="1"
                    CornerRadius="2">
              <Path x:Name="CheckMark"
                    Data="M 2,8 L 6,12 L 14,4"
                    Stroke="White"
                    StrokeThickness="2"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    Visibility="Collapsed" />
            </Border>
            <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True" />
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Box" Property="Background" Value="{DynamicResource Theme.Accent}" />
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
              <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Theme.BorderActive}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- GroupBox: header INSIDE border with divider — no overflow of buttons/labels -->
  <Style TargetType="GroupBox">
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.GroupBoxBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource Theme.GroupBoxBg}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.TextBody}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="GroupBox">
          <Border BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Background="{TemplateBinding Background}"
                  CornerRadius="4"
                  SnapsToDevicePixels="True">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <!-- Заголовок внутри рамки, со строкой-разделителем снизу -->
              <Border Grid.Row="0"
                      Padding="10,7"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="0,0,0,1">
                <ContentPresenter ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                  TextElement.FontWeight="SemiBold" />
              </Border>
              <ContentPresenter Grid.Row="1"
                                Margin="{TemplateBinding Padding}" />
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Скролл: один PART_Track (требование WPF), команды меняются по Orientation -->
  <Style TargetType="ScrollBar">
    <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False" />
    <Setter Property="Stylus.IsFlicksEnabled" Value="False" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.ScrollBarThumb}" />
    <Setter Property="Background" Value="{DynamicResource Theme.ScrollBarTrackBg}" />
    <Setter Property="Width" Value="10" />
    <Setter Property="MinWidth" Value="10" />
    <Setter Property="Height" Value="Auto" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid x:Name="GridRoot" Background="{TemplateBinding Background}">
            <Track x:Name="PART_Track"
                   Orientation="{TemplateBinding Orientation}"
                   IsDirectionReversed="True"
                   Focusable="False">
              <Track.DecreaseRepeatButton>
                <RepeatButton x:Name="PART_LineUpButton"
                              Command="ScrollBar.LineUpCommand"
                              Style="{StaticResource FluentSliderRepeatButton}" />
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb x:Name="Thumb">
                  <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                      <Border x:Name="ThumbBorder"
                              Background="{DynamicResource Theme.ScrollBarThumb}"
                              BorderBrush="{DynamicResource Theme.MenuPopupBorder}"
                              BorderThickness="1"
                              CornerRadius="4"
                              Margin="1" />
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource Theme.ScrollBarThumbHover}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                          <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource Theme.ScrollBarThumbPressed}" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Thumb.Template>
                </Thumb>
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton x:Name="PART_LineDownButton"
                              Command="ScrollBar.LineDownCommand"
                              Style="{StaticResource FluentSliderRepeatButton}" />
              </Track.IncreaseRepeatButton>
            </Track>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
              <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True" />
              <Setter TargetName="PART_LineUpButton" Property="Command" Value="{x:Static ScrollBar.LineUpCommand}" />
              <Setter TargetName="PART_LineDownButton" Property="Command" Value="{x:Static ScrollBar.LineDownCommand}" />
              <Setter Property="Width" Value="10" />
              <Setter Property="MinWidth" Value="10" />
              <Setter Property="Height" Value="Auto" />
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
              <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
              <Setter TargetName="PART_LineUpButton" Property="Command" Value="{x:Static ScrollBar.LineLeftCommand}" />
              <Setter TargetName="PART_LineDownButton" Property="Command" Value="{x:Static ScrollBar.LineRightCommand}" />
              <Setter Property="Height" Value="10" />
              <Setter Property="MinHeight" Value="10" />
              <Setter Property="Width" Value="Auto" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Горизонтальный слайдер: тёмный трек, синий ползунок -->
  <Style TargetType="Slider">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Accent}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid SnapsToDevicePixels="True">
            <Border x:Name="TrackBg"
                    Height="4"
                    VerticalAlignment="Center"
                    CornerRadius="2"
                    Background="{DynamicResource Theme.SliderTrackBg}" />
            <Track x:Name="PART_Track">
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="Slider.DecreaseLarge" Style="{StaticResource FluentSliderRepeatButton}" />
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb x:Name="SliderThumb">
                  <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                      <Border x:Name="Sb"
                              Width="16"
                              Height="16"
                              CornerRadius="8"
                              Background="{DynamicResource Theme.SliderThumb}"
                              BorderBrush="{DynamicResource Theme.MenuPopupBorder}"
                              BorderThickness="1" />
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="Sb" Property="Background" Value="{DynamicResource Theme.SliderThumbHover}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                          <Setter TargetName="Sb" Property="Background" Value="{DynamicResource Theme.ScrollBarThumbPressed}" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Thumb.Template>
                </Thumb>
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="Slider.IncreaseLarge" Style="{StaticResource FluentSliderRepeatButton}" />
              </Track.IncreaseRepeatButton>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
