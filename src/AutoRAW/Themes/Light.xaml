<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="ComboBoxStyles.xaml" />
  </ResourceDictionary.MergedDictionaries>
  <SolidColorBrush x:Key="Theme.WindowBg" Color="#F2F3F5" />
  <SolidColorBrush x:Key="Theme.MenuBarBg" Color="#FFFFFF" />
  <SolidColorBrush x:Key="Theme.MenuBarBorder" Color="#D8DADC" />
  <SolidColorBrush x:Key="Theme.CardBg" Color="#FFFFFF" />
  <SolidColorBrush x:Key="Theme.CardBorder" Color="#D8DADC" />
  <SolidColorBrush x:Key="Theme.TextPrimary" Color="#1A1A1A" />
  <SolidColorBrush x:Key="Theme.TextSecondary" Color="#5C5C5C" />
  <SolidColorBrush x:Key="Theme.TextBody" Color="#333333" />
  <SolidColorBrush x:Key="Theme.TextMuted" Color="#444444" />
  <SolidColorBrush x:Key="Theme.TextSubtle" Color="#555555" />
  <SolidColorBrush x:Key="Theme.TextHint" Color="#666666" />
  <SolidColorBrush x:Key="Theme.PreviewSurface" Color="#FAFAFA" />
  <SolidColorBrush x:Key="Theme.LogSurface" Color="#E8EDF2" />
  <SolidColorBrush x:Key="Theme.LogItemHover" Color="#D8DEE6" />
  <SolidColorBrush x:Key="Theme.ChatBubbleText" Color="#0F1419" />
  <SolidColorBrush x:Key="Theme.ChatBubbleTime" Color="#5B9BD1" />
  <SolidColorBrush x:Key="Theme.ChatCopyHover" Color="#D0D8E0" />

  <SolidColorBrush x:Key="Theme.BubbleNormal" Color="#FFFFFF" />
  <SolidColorBrush x:Key="Theme.BubbleBorderNormal" Color="#D0D4DC" />
  <SolidColorBrush x:Key="Theme.BubbleZona" Color="#D9F0FF" />
  <SolidColorBrush x:Key="Theme.BubbleBorderZona" Color="#A8D4F0" />
  <SolidColorBrush x:Key="Theme.BubbleError" Color="#FFE0E0" />
  <SolidColorBrush x:Key="Theme.BubbleBorderError" Color="#E06060" />
  <SolidColorBrush x:Key="Theme.BubblePause" Color="#FFF4C8" />
  <SolidColorBrush x:Key="Theme.BubbleBorderPause" Color="#E0B020" />
  <SolidColorBrush x:Key="Theme.BubbleDone" Color="#D4F0DC" />
  <SolidColorBrush x:Key="Theme.BubbleBorderDone" Color="#50A860" />
  <SolidColorBrush x:Key="Theme.BubbleTextError" Color="#0F1419" />
  <SolidColorBrush x:Key="Theme.BubbleTextPause" Color="#0F1419" />
  <SolidColorBrush x:Key="Theme.BubbleTextDone" Color="#0F1419" />
  <SolidColorBrush x:Key="Theme.Accent" Color="#0F6CBD" />
  <SolidColorBrush x:Key="Theme.AccentHover" Color="#39940E" />
  <SolidColorBrush x:Key="Theme.AccentPressed" Color="#0A5A9A" />
  <SolidColorBrush x:Key="Theme.BorderActive" Color="#0F6CBD" />
  <SolidColorBrush x:Key="Theme.ButtonSecondaryBg" Color="#FFFFFF" />
  <SolidColorBrush x:Key="Theme.ButtonSecondaryBorder" Color="#C8C8C8" />
  <SolidColorBrush x:Key="Theme.ButtonDisabledBg" Color="#E4E4E4" />
  <SolidColorBrush x:Key="Theme.ButtonDisabledFg" Color="#555555" />
  <SolidColorBrush x:Key="Theme.ButtonDisabledBorder" Color="#B0B0B0" />
  <SolidColorBrush x:Key="Theme.ProgressTrack" Color="#E2E4E8" />
  <SolidColorBrush x:Key="Theme.DialogBg" Color="#FAFAFA" />
  <SolidColorBrush x:Key="Theme.DialogBorder" Color="#D8DADC" />
  <SolidColorBrush x:Key="Theme.Hyperlink" Color="#0969DA" />
  <SolidColorBrush x:Key="Theme.InfoPanelBg" Color="#F0F4FF" />
  <SolidColorBrush x:Key="Theme.InfoPanelBorder" Color="#C8D8F0" />
  <SolidColorBrush x:Key="Theme.FieldReadonlyBg" Color="#F5F5F5" />
  <SolidColorBrush x:Key="Theme.InputBackground" Color="#FFFFFF" />
  <SolidColorBrush x:Key="Theme.InputBorder" Color="#ABADB3" />
  <SolidColorBrush x:Key="Theme.GithubTitle" Color="#0D1117" />
  <SolidColorBrush x:Key="Theme.GithubMuted" Color="#57606A" />
  <SolidColorBrush x:Key="Theme.GithubSection" Color="#24292F" />
  <SolidColorBrush x:Key="Theme.GithubPaneBorder" Color="#D0D7DE" />
  <SolidColorBrush x:Key="Theme.GithubPaneBg" Color="#FFFFFF" />
  <SolidColorBrush x:Key="Theme.AlphaChromeBorder" Color="#D0D0D0" />
  <SolidColorBrush x:Key="Theme.ComboBoxBackground" Color="#FFFFFF" />
  <SolidColorBrush x:Key="Theme.ListBorder" Color="#D8DADC" />
  <SolidColorBrush x:Key="Theme.GroupBoxBorder" Color="#D8DADC" />
  <SolidColorBrush x:Key="Theme.GroupBoxBg" Color="#FFFFFF" />
  <SolidColorBrush x:Key="Theme.DialogChromeBorder" Color="#D8DADC" />
  <SolidColorBrush x:Key="Theme.DialogChromeBg" Color="#FAFAFA" />

  <Style TargetType="TextBox">
    <Setter Property="Background" Value="{StaticResource Theme.InputBackground}" />
    <Setter Property="Foreground" Value="{StaticResource Theme.TextPrimary}" />
    <Setter Property="BorderBrush" Value="{StaticResource Theme.InputBorder}" />
    <Setter Property="CaretBrush" Value="{StaticResource Theme.TextPrimary}" />
  </Style>

  <Style TargetType="GroupBox">
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="BorderBrush" Value="{StaticResource Theme.GroupBoxBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{StaticResource Theme.GroupBoxBg}" />
    <Setter Property="Foreground" Value="{StaticResource Theme.TextBody}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="GroupBox">
          <Border BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Background="{TemplateBinding Background}"
                  CornerRadius="4"
                  SnapsToDevicePixels="True">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Border Grid.Row="0"
                      Padding="10,7"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="0,0,0,1">
                <ContentPresenter ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                  TextElement.FontWeight="SemiBold" />
              </Border>
              <ContentPresenter Grid.Row="1"
                                Margin="{TemplateBinding Padding}" />
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
