<Window x:Class="AutoRAW.AddProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый профиль"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="480"
        MinHeight="220"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.WindowBg}"
        TextElement.Foreground="{DynamicResource Theme.TextPrimary}">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
    <StackPanel>

      <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource Theme.TextSubtle}" Margin="0,0,0,12"
                 Text="Укажите папку с профилем (profile.json и reference/zona, или каталог из profiles проекта). Профиль будет скопирован в %LocalAppData%\AutoRAW\user files\Profile." />

      <TextBlock Text="Имя профиля" FontWeight="SemiBold" Margin="0,0,0,4" />
      <TextBox x:Name="ProfileNameBox" Margin="0,0,0,14" />

      <TextBlock Text="Папка профиля" FontWeight="SemiBold" Margin="0,0,0,4" />
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="ProfileFolderBox" Grid.Column="0" Margin="0,0,8,0" VerticalContentAlignment="Center" />
        <Button Grid.Column="1" Content="Обзор…" Padding="10,4" Click="BrowseProfileFolder" />
      </Grid>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button MinWidth="96" Margin="0,0,8,0" IsDefault="True" Content="OK" Padding="12,6" Click="OkClick" />
        <Button MinWidth="96" IsCancel="True" Content="Отмена" Padding="12,6" Click="CancelClick" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Window>
