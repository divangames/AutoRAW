<Window x:Class="AutoRAW.AddProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый профиль"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="500"
        MinHeight="360"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
    <StackPanel>

      <TextBlock Text="Имя профиля" FontWeight="SemiBold" Margin="0,0,0,4" />
      <TextBox x:Name="ProfileNameBox" Margin="0,0,0,14" Text="Новый профиль" />

      <TextBlock Text="Папка с референсами" FontWeight="SemiBold" Margin="0,0,0,4" />
      <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="RefPathBox" Grid.Column="0" Margin="0,0,8,0" VerticalContentAlignment="Center" />
        <Button Grid.Column="1" Content="Обзор…" Padding="10,4" Click="BrowseRef" />
      </Grid>

      <TextBlock Text="Папка с zona" FontWeight="SemiBold" Margin="0,0,0,4" />
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="ZonaPathBox" Grid.Column="0" Margin="0,0,8,0" VerticalContentAlignment="Center" />
        <Button Grid.Column="1" Content="Обзор…" Padding="10,4" Click="BrowseZona" />
      </Grid>

      <GroupBox Header="Цветовой профиль (.xmp)" Padding="10" Margin="0,0,0,14">
        <StackPanel>
          <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#555" Margin="0,0,0,8"
                     Text="Загрузите XMP-пресет Lightroom / Camera Raw. Если не выбрать — цветокоррекция не применяется." />

          <!-- Выбор XMP -->
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="XmpPathBox"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Background="#F5F5F5"
                     Text="(файл не выбран)" />
            <Button Grid.Column="1" Content="Загрузить .xmp…" Padding="10,4" Click="BrowseXmp" />
          </Grid>

          <!-- Краткая сводка параметров -->
          <Border x:Name="XmpSummaryBorder"
                  Background="#F0F4FF" BorderBrush="#C8D8F0" BorderThickness="1"
                  CornerRadius="4" Padding="10,8"
                  Visibility="Collapsed">
            <TextBlock x:Name="XmpSummaryBlock"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="#333" />
          </Border>

          <CheckBox x:Name="StdColorCheck"
                    Margin="0,10,0,0"
                    Content="Стандартный цветовой профиль (sRGB, без встроенного ICC)"
                    IsChecked="True" />
        </StackPanel>
      </GroupBox>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button MinWidth="96" Margin="0,0,8,0" IsDefault="True" Content="OK" Padding="12,6" Click="OkClick" />
        <Button MinWidth="96" IsCancel="True" Content="Отмена" Padding="12,6" Click="CancelClick" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Window>
