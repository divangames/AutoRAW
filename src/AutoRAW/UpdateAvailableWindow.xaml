<Window x:Class="AutoRAW.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Доступно обновление"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="520"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.WindowBg}">
  <Border Padding="20"
          BorderBrush="{DynamicResource Theme.DialogChromeBorder}"
          BorderThickness="1"
          CornerRadius="2"
          Background="{DynamicResource Theme.DialogChromeBg}">
    <StackPanel>
      <TextBlock FontSize="17"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource Theme.GithubTitle}"
                 TextWrapping="Wrap"
                 x:Name="HeadlineBlock" />
      <TextBlock Margin="0,8,0,14"
                 FontSize="13"
                 Foreground="{DynamicResource Theme.GithubMuted}"
                 LineHeight="20"
                 TextWrapping="Wrap"
                 Text="Доступна более новая версия. Установщик скачается и запустится; программа может быть закрыта на время установки." />
      <TextBlock FontSize="12"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource Theme.GithubSection}"
                 Margin="0,0,0,8"
                 Text="Описание релиза" />
      <Border BorderBrush="{DynamicResource Theme.GithubPaneBorder}"
              BorderThickness="1"
              Background="{DynamicResource Theme.GithubPaneBg}"
              CornerRadius="8"
              Height="300"
              Margin="0,0,0,16"
              SnapsToDevicePixels="True">
        <WebBrowser x:Name="BodyBrowser" />
      </Border>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="SkipButton"
                Content="Пропустить"
                Padding="16,9"
                Margin="0,0,10,0"
                IsCancel="True"
                Click="Skip_Click" />
        <Button Content="Обновить сейчас"
                Padding="16,9"
                FontWeight="SemiBold"
                IsDefault="True"
                Click="Update_Click" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
