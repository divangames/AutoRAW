<Window x:Class="AutoRAW.TextDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Width="820"
        Height="640"
        MinWidth="560"
        MinHeight="400"
        Background="#F2F3F5">
  <DockPanel Margin="0">
    <Border DockPanel.Dock="Top"
            Background="White"
            BorderBrush="#D8DADC"
            BorderThickness="0,0,0,1"
            Padding="12,10">
      <TextBlock x:Name="PathText"
                 FontSize="11"
                 Foreground="#666"
                 TextWrapping="Wrap" />
    </Border>
    <WebBrowser x:Name="BodyBrowser" />
  </DockPanel>
</Window>
