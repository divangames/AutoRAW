<Window x:Class="AutoRAW.TextDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Width="820"
        Height="640"
        MinWidth="560"
        MinHeight="400"
        Background="{DynamicResource Theme.WindowBg}">
  <DockPanel Margin="0">
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource Theme.MenuBarBg}"
            BorderBrush="{DynamicResource Theme.MenuBarBorder}"
            BorderThickness="0,0,0,1"
            Padding="12,10">
      <TextBlock x:Name="PathText"
                 FontSize="11"
                 Foreground="{DynamicResource Theme.TextHint}"
                 TextWrapping="Wrap" />
    </Border>
    <WebBrowser x:Name="BodyBrowser" />
  </DockPanel>
</Window>
