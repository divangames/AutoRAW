<Window x:Class="AutoRAW.ColorProfileEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Цветовой профиль"
        WindowStartupLocation="CenterOwner"
        Width="960"
        Height="660"
        MinWidth="720"
        MinHeight="520"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" MinHeight="180" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               TextWrapping="Wrap"
               Margin="0,0,0,12"
               Foreground="#444"
               Text="Загрузите .xmp-пресет (Lightroom / Camera Raw). Превью обновляется автоматически после выбора файла." />

    <!-- Превью До / После -->
    <Grid Grid.Row="1" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Margin="0,0,8,0">
        <TextBlock FontWeight="SemiBold" Margin="0,0,0,6" Text="Исходник (до)" />
        <Border BorderBrush="#DDD" BorderThickness="1" Background="#FAFAFA" MinHeight="200">
          <Image x:Name="BeforeImage"
                 MaxHeight="340"
                 Stretch="Uniform"
                 RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>
      </StackPanel>
      <StackPanel Grid.Column="1" Margin="8,0,0,0">
        <TextBlock FontWeight="SemiBold" Margin="0,0,0,6" Text="После настроек" />
        <Border BorderBrush="#DDD" BorderThickness="1" Background="#FAFAFA" MinHeight="200">
          <Image x:Name="AfterImage"
                 MaxHeight="340"
                 Stretch="Uniform"
                 RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>
      </StackPanel>
    </Grid>

    <!-- XMP-файл и параметры -->
    <GroupBox Grid.Row="2" Header="XMP-пресет" Padding="10" Margin="0,0,0,12">
      <StackPanel>
        <!-- Выбор файла -->
        <Grid Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="XmpPathBox"
                   Grid.Column="0"
                   Margin="0,0,8,0"
                   IsReadOnly="True"
                   VerticalContentAlignment="Center"
                   Background="#F5F5F5"
                   Text="(файл не выбран)" />
          <Button Grid.Column="1"
                  Padding="12,6"
                  Margin="0,0,8,0"
                  Content="Загрузить .xmp…"
                  Click="BrowseXmpClick" />
          <Button Grid.Column="2"
                  Padding="12,6"
                  Content="Обновить превью"
                  Click="RefreshPreviewClick" />
        </Grid>

        <!-- Сводка параметров из XMP -->
        <Border Background="#F0F4FF" BorderBrush="#C8D8F0" BorderThickness="1"
                CornerRadius="4" Padding="10,8">
          <StackPanel>
            <TextBlock x:Name="XmpSummaryBlock"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="#333"
                       Text="Параметры появятся после загрузки XMP-файла." />
          </StackPanel>
        </Border>

        <!-- Стандартный цветовой профиль -->
        <CheckBox x:Name="StdColorCheck"
                  Margin="0,10,0,0"
                  Content="Стандартный цветовой профиль (sRGB, без встроенного ICC)"
                  IsChecked="True" />
      </StackPanel>
    </GroupBox>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button MinWidth="100" Margin="0,0,8,0" IsDefault="True" Padding="12,6" Content="OK" Click="OkClick" />
      <Button MinWidth="100" IsCancel="True" Padding="12,6" Content="Отмена" Click="CancelClick" />
    </StackPanel>
  </Grid>
</Window>
