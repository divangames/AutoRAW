<Window x:Class="AutoRAW.ZonaTelegramSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Telegram — уведомления ZONA"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="480"
        SizeToContent="Height"
        Background="{DynamicResource Theme.DialogBg}"
        TextElement.Foreground="{DynamicResource Theme.TextPrimary}">
  <Window.Resources>
    <Style x:Key="DialogPrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.AccentHover}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.AccentPressed}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.ButtonDisabledBg}" />
                <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonDisabledFg}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource Theme.ButtonSecondaryBg}" />
      <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonSecondaryBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.ListItemHover}" />
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Theme.BorderActive}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.AccentPressed}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.ButtonDisabledBg}" />
                <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonDisabledFg}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Padding="20"
          BorderBrush="{DynamicResource Theme.DialogBorder}"
          BorderThickness="1">
    <StackPanel>
      <TextBlock Text="ZONA в Telegram"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Margin="0,0,0,8" />
      <TextBlock TextWrapping="Wrap"
                 FontSize="12"
                 LineHeight="18"
                 Foreground="{DynamicResource Theme.TextMuted}"
                 Margin="0,0,0,14"
                 Text="Создайте бота через @BotFather, добавьте его в чат и укажите токен и ID чата. ZONA пришлёт сообщения о готовности пакета, ошибках и отмене." />

      <CheckBox x:Name="EnabledCheck"
                Content="Включить уведомления в Telegram"
                Foreground="{DynamicResource Theme.TextBody}"
                Margin="0,0,0,12" />

      <Grid Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="Токен бота"
                   FontSize="12"
                   Foreground="{DynamicResource Theme.TextSecondary}"
                   VerticalAlignment="Center" />
        <Button x:Name="UnlockCredentialsBtn"
                Grid.Column="1"
                Content="Изменить…"
                Padding="8,4"
                FontSize="11"
                Style="{StaticResource DialogSecondaryButtonStyle}"
                Click="UnlockCredentialsClick" />
      </Grid>
      <PasswordBox x:Name="TokenBox"
                   Margin="0,0,0,4"
                   Padding="8,6"
                   MinHeight="28" />
      <TextBlock x:Name="CredentialsHintText"
                 TextWrapping="Wrap"
                 FontSize="11"
                 Foreground="{DynamicResource Theme.TextHint}"
                 Margin="0,0,0,10"
                 Visibility="Collapsed"
                 Text="Токен и ID чата сохранены на этом компьютере. Чтобы изменить — нажмите «Изменить…» и введите пароль." />

      <TextBlock Text="ID чата (число или @username)"
                 FontSize="12"
                 Foreground="{DynamicResource Theme.TextSecondary}"
                 Margin="0,0,0,4" />
      <TextBox x:Name="ChatIdBox"
               Margin="0,0,0,10"
               Padding="8,6"
               MinHeight="28" />

      <TextBlock x:Name="StatusText"
                 TextWrapping="Wrap"
                 FontSize="11"
                 Foreground="{DynamicResource Theme.TextHint}"
                 Margin="0,0,0,12"
                 Visibility="Collapsed" />

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,4,0,0">
        <Button x:Name="TestBtn"
                MinWidth="110"
                Margin="0,0,8,0"
                Content="Проверить"
                Style="{StaticResource DialogSecondaryButtonStyle}"
                Click="TestClick" />
        <Button MinWidth="88"
                Margin="0,0,8,0"
                IsDefault="True"
                Content="Сохранить"
                Style="{StaticResource DialogPrimaryButtonStyle}"
                Click="SaveClick" />
        <Button MinWidth="88"
                IsCancel="True"
                Content="Отмена"
                Style="{StaticResource DialogSecondaryButtonStyle}" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
