<Window x:Class="AutoRAW.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="360"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock x:Name="MessageText" Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10" />
    <TextBox x:Name="InputText" Grid.Row="1" Margin="0,0,0,12" MinHeight="26" />
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button MinWidth="88" Margin="0,0,8,0" IsDefault="True" Click="OkClick" Content="OK" />
      <Button MinWidth="88" IsCancel="True" Click="CancelClick" Content="Отмена" />
    </StackPanel>
  </Grid>
</Window>
