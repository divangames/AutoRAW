<Window x:Class="AutoRAW.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="420"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.DialogBg}">
  <Border Padding="22"
          BorderBrush="{DynamicResource Theme.DialogBorder}"
          BorderThickness="1">
    <StackPanel>
      <TextBlock Text="AutoRAW"
                 FontSize="22"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource Theme.TextPrimary}" />
      <TextBlock x:Name="VersionBlock"
                 Margin="0,6,0,16"
                 FontSize="13"
                 Foreground="{DynamicResource Theme.TextSubtle}" />

      <TextBlock FontSize="13" TextWrapping="Wrap" Foreground="{DynamicResource Theme.TextBody}" Margin="0,0,0,10">
        Пакетная обработка изображений и RAW: кадрирование по референсу или по технологии «Zona» (собственная разработка для AutoRAW).
      </TextBlock>

      <TextBlock FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource Theme.TextBody}">
        <Run Text="Разработано командой: " />
        <Hyperlink NavigateUri="https://белаякоробка.рф/"
                   RequestNavigate="Link_OnRequestNavigate"
                   Foreground="{DynamicResource Theme.Hyperlink}"
                   FontWeight="SemiBold">WhiteCube</Hyperlink>
      </TextBlock>
      <TextBlock Text="Разработчик: Радыгин Иван"
                 FontSize="13"
                 Foreground="{DynamicResource Theme.TextBody}"
                 Margin="0,0,0,18" />

      <Button Content="Закрыть"
              HorizontalAlignment="Right"
              MinWidth="100"
              Padding="12,8"
              IsDefault="True"
              IsCancel="True"
              Click="Close_Click" />
    </StackPanel>
  </Border>
</Window>
