<Window x:Class="AutoRAW.UpdateDownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Загрузка обновления"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="420"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.DialogBg}">
  <Border Padding="18"
          BorderBrush="{DynamicResource Theme.DialogBorder}"
          BorderThickness="1">
    <StackPanel>
      <TextBlock Text="Скачивание установщика…"
                 FontSize="14"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource Theme.TextPrimary}"
                 Margin="0,0,0,10" />
      <TextBlock x:Name="StatusBlock"
                 FontSize="12"
                 Foreground="{DynamicResource Theme.TextMuted}"
                 TextWrapping="Wrap"
                 Margin="0,0,0,8" />
      <ProgressBar x:Name="DownloadProgress"
                   Height="10"
                   Minimum="0"
                   Maximum="100"
                   IsIndeterminate="True" />
    </StackPanel>
  </Border>
</Window>
