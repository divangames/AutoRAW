<Window x:Class="AutoRAW.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AutoRAW.ViewModels"
        xmlns:conv="clr-namespace:AutoRAW.Converters"
        mc:Ignorable="d"
        Title="AutoRAW"
        Icon="Assets/favicon.ico"
        Height="720"
        Width="620"
        MinHeight="720"
        MaxHeight="720"
        MinWidth="620"
        MaxWidth="620"
        Background="{DynamicResource Theme.WindowBg}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI"
        FontSize="12"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <conv:PreviewScrollMinHeightConverter x:Key="PreviewScrollMinHeight" />
    <conv:BoolToPreviewRowLengthConverter x:Key="BoolToPreviewRowLength" />

    <Style x:Key="LogToolButtonStyle" TargetType="Button">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Background" Value="{DynamicResource Theme.ButtonSecondaryBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonSecondaryBorder}" />
      <Setter Property="Foreground" Value="{DynamicResource Theme.TextBody}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PreviewLoadProgressStyle" TargetType="ProgressBar">
      <Setter Property="Height" Value="4" />
      <Setter Property="Margin" Value="0,4,0,0" />
      <Setter Property="Foreground" Value="{DynamicResource Theme.Accent}" />
      <Setter Property="Background" Value="{DynamicResource Theme.ProgressTrack}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Visibility" Value="Collapsed" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsPreviewLoading}" Value="True">
          <Setter Property="Visibility" Value="Visible" />
          <Setter Property="IsIndeterminate" Value="True" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <MultiTrigger>
          <MultiTrigger.Conditions>
            <Condition Property="IsMouseOver" Value="True" />
            <Condition Property="IsEnabled" Value="True" />
          </MultiTrigger.Conditions>
          <Setter Property="Background" Value="{DynamicResource Theme.AccentHover}" />
        </MultiTrigger>
        <MultiTrigger>
          <MultiTrigger.Conditions>
            <Condition Property="IsPressed" Value="True" />
            <Condition Property="IsEnabled" Value="True" />
          </MultiTrigger.Conditions>
          <Setter Property="Background" Value="{DynamicResource Theme.AccentPressed}" />
        </MultiTrigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Background" Value="{DynamicResource Theme.ButtonDisabledBg}" />
          <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonDisabledFg}" />
          <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonDisabledBorder}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="Cursor" Value="Arrow" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="MinWidth" Value="88" />
      <Setter Property="Background" Value="{DynamicResource Theme.ButtonSecondaryBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonSecondaryBorder}" />
      <Setter Property="Foreground" Value="{DynamicResource Theme.TextBody}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <MultiTrigger>
          <MultiTrigger.Conditions>
            <Condition Property="IsMouseOver" Value="True" />
            <Condition Property="IsEnabled" Value="True" />
          </MultiTrigger.Conditions>
          <Setter Property="Background" Value="{DynamicResource Theme.ListItemHover}" />
          <Setter Property="BorderBrush" Value="{DynamicResource Theme.BorderActive}" />
        </MultiTrigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Background" Value="{DynamicResource Theme.ButtonDisabledBg}" />
          <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonDisabledFg}" />
          <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonDisabledBorder}" />
          <Setter Property="Cursor" Value="Arrow" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CancelBatchButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Width" Value="76" />
      <Setter Property="Padding" Value="8,5" />
    </Style>

  </Window.Resources>

  <DockPanel Background="{DynamicResource Theme.WindowBg}"
             TextElement.Foreground="{DynamicResource Theme.TextBody}">
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource Theme.MenuBarBg}"
            BorderBrush="{DynamicResource Theme.MenuBarBorder}"
            BorderThickness="0,0,0,1">
      <Menu Background="Transparent" Padding="4,2">
        <MenuItem x:Name="MenuProfileRoot"
                  Header="Профиль"
                  SubmenuOpened="ProductSubmenu_OnSubmenuOpened"
                  Loaded="MenuProfileRoot_OnLoaded" />
        <MenuItem Header="Вид">
          <MenuItem Header="Окна">
            <MenuItem Header="Показать чат Zona"
                      IsCheckable="True"
                      StaysOpenOnClick="True"
                      IsChecked="{Binding IsLogPanelVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <MenuItem Header="Показать цветовой профиль"
                      IsCheckable="True"
                      StaysOpenOnClick="True"
                      IsChecked="{Binding IsColorProfilePanelVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <MenuItem Header="Показать превью"
                      IsCheckable="True"
                      StaysOpenOnClick="True"
                      IsChecked="{Binding IsPreviewPanelVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </MenuItem>
          <MenuItem Header="Тема">
            <MenuItem Header="Светлая"
                      IsCheckable="True"
                      StaysOpenOnClick="True"
                      IsChecked="{Binding IsThemeMenuLight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <MenuItem Header="Тёмная"
                      IsCheckable="True"
                      StaysOpenOnClick="True"
                      IsChecked="{Binding IsThemeMenuDark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <MenuItem Header="Как в системе"
                      IsCheckable="True"
                      StaysOpenOnClick="True"
                      IsChecked="{Binding IsThemeMenuSystem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </MenuItem>
          <MenuItem Header="Расширенный режим"
                    IsCheckable="True"
                    StaysOpenOnClick="True"
                    IsChecked="{Binding IsAdvancedView, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </MenuItem>
        <MenuItem Header="Настройки">
          <MenuItem Header="Telegram ZONA…" Command="{Binding ShowTelegramSettingsCommand}" />
        </MenuItem>
        <MenuItem Header="Справка">
          <MenuItem Header="Проверить обновление" Command="{Binding CheckForUpdatesCommand}" />
          <Separator />
          <MenuItem Header="О программе…" Command="{Binding ShowAboutCommand}" />
          <MenuItem Header="Инструкция" Command="{Binding ShowInstructionCommand}" />
          <MenuItem Header="Чендж лог" Command="{Binding ShowChangelogCommand}" />
        </MenuItem>
      </Menu>
    </Border>

    <Grid Margin="14,12,14,12">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <ScrollViewer x:Name="MainScroll"
                    Grid.Row="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Padding="0,0,4,0">
        <Grid>
          <!-- Простой режим -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsAdvancedView}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.MinHeight>
              <MultiBinding Converter="{StaticResource PreviewScrollMinHeight}">
                <Binding ElementName="MainScroll" Path="ViewportHeight" />
                <Binding Path="IsPreviewPanelVisible" />
              </MultiBinding>
            </Grid.MinHeight>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="{Binding IsPreviewPanelVisible, Converter={StaticResource BoolToPreviewRowLength}}" />
            </Grid.RowDefinitions>

            <!-- Шапка: профиль + главное действие (вертикальная раскладка) -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Theme.CardBg}"
                    BorderBrush="{DynamicResource Theme.CardBorder}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="12,10"
                    Margin="0,0,0,8">
              <StackPanel>
                <TextBlock FontSize="13" Foreground="{DynamicResource Theme.TextPrimary}">
                  <Run Text="Профиль: " />
                  <Run Text="{Binding SelectedProduct.DisplayName, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           FontSize="11.5"
                           Foreground="{DynamicResource Theme.TextSecondary}"
                           LineHeight="16"
                           Text="Выбранный профиль (меню «Профиль») задаёт папки reference и zona (маркёры технологии Zona). Смените профиль, если нужен другой тип товара." />
                <Grid Margin="0,10,0,0"
                      ToolTip="Запуск, пауза и продолжение — одна кнопка. «Отмена» прерывает пакет. Над журналом — полоса прогресса (например 94/100).">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Button Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          MinWidth="0"
                          Style="{StaticResource PrimaryActionButtonStyle}"
                          Command="{Binding BatchPrimaryClickCommand}"
                          Content="{Binding BatchPrimaryButtonText}" />
                  <Button Grid.Column="2"
                          Style="{StaticResource CancelBatchButtonStyle}"
                          Command="{Binding CancelBatchCommand}"
                          Content="Отмена"
                          ToolTip="Прервать кадрирование (строка в журнале будет красной)" />
                </Grid>
                <CheckBox Margin="0,10,0,0"
                          FontSize="12"
                          Content="Сохранять результат в WebP (.webp); снять галочку — JPEG (.jpg)"
                          IsChecked="{Binding SaveAsWebP, Mode=TwoWay}" />
              </StackPanel>
            </Border>

            <GroupBox Grid.Row="1" Header="Папки">
              <StackPanel>
                <TextBlock FontSize="12" Foreground="{DynamicResource Theme.TextBody}" Text="Товар (вход)" />
                <TextBlock Margin="0,2,0,4"
                           FontSize="10.5"
                           Foreground="{DynamicResource Theme.TextHint}"
                           Text="Обзор… или перетащите сюда папку / файлы из Проводника" />
                <Border Tag="InputDropZone"
                        Padding="8,8"
                        Margin="0,0,0,2"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource Theme.CardBorder}"
                        Background="Transparent">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Margin="0,0,8,0"
                             Height="26"
                             VerticalContentAlignment="Center"
                             IsReadOnly="False"
                             Text="{Binding InputFolder, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseInputFolderCommand}"
                            Content="Обзор…" />
                  </Grid>
                </Border>
                <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="{DynamicResource Theme.TextBody}" Text="Выход" />
                <Grid Margin="0,4,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0"
                           Margin="0,0,8,0"
                           Height="26"
                           VerticalContentAlignment="Center"
                           Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Пусто — &lt;вход&gt;\webp или jpg\&lt;подпапка&gt;\ (структура как во входе). Задана папка — &lt;выход&gt;\&lt;подпапка&gt;\." />
                  <Button Grid.Column="1"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Command="{Binding BrowseOutputFolderCommand}"
                          Content="Обзор…" />
                </Grid>
              </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="2"
                      Header="Цветовой профиль"
                      Visibility="{Binding IsColorProfilePanelVisible, Converter={StaticResource BoolToVis}}">
              <StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Theme.TextMuted}" Text="{Binding ColorSpaceSummaryText, Mode=OneWay}" />
                <TextBlock Margin="0,2,0,6" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource Theme.TextHint}" Text="{Binding ColorNumericSummary, Mode=OneWay}" />
                <CheckBox FontSize="12"
                          Content="Применить коррекцию цвета (альфа)"
                          IsChecked="{Binding ApplyColorCorrection, Mode=TwoWay}"
                          ToolTip="Включение требует подтверждения. При смене профиля сбрасывается." />
                <Button Margin="0,8,0,0"
                        HorizontalAlignment="Stretch"
                        Padding="10,5"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="Настроить профиль…"
                        Command="{Binding EditColorProfileCommand}" />
              </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="3"
                      Header="Превью"
                      VerticalAlignment="Stretch"
                      Visibility="{Binding IsPreviewPanelVisible, Converter={StaticResource BoolToVis}}">
              <Grid VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsPreviewLoading, Converter={StaticResource BoolToVis}}">
                  <TextBlock FontSize="11.5"
                             Foreground="{DynamicResource Theme.TextMuted}"
                             TextWrapping="Wrap"
                             Text="{Binding PreviewStatusText, Mode=OneWay}" />
                  <ProgressBar Style="{StaticResource PreviewLoadProgressStyle}" />
                </StackPanel>
                <Grid Grid.Row="1" Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             VerticalAlignment="Center"
                             Margin="0,0,12,0"
                             FontSize="11"
                             Foreground="{DynamicResource Theme.TextSubtle}"
                             TextWrapping="Wrap"
                             Text="Анализ (длинная сторона)" />
                  <StackPanel Grid.Column="1">
                    <Slider Minimum="512"
                            Maximum="4096"
                            TickFrequency="64"
                            IsSnapToTickEnabled="True"
                            Value="{Binding AnalysisMaxEdge, Mode=TwoWay}" />
                    <TextBlock Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource Theme.TextHint}"
                               Text="{Binding AnalysisMaxEdge, StringFormat={}{0:0} px}" />
                  </StackPanel>
                </Grid>
                <Grid Grid.Row="2"
                      Margin="0,4,0,0"
                      VerticalAlignment="Stretch">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <DockPanel Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Stretch">
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,4"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.TextBody}"
                               Text="До" />
                    <Border BorderBrush="{DynamicResource Theme.CardBorder}"
                            BorderThickness="1"
                            Background="{DynamicResource Theme.PreviewSurface}"
                            CornerRadius="1"
                            VerticalAlignment="Stretch"
                            MinHeight="120">
                      <Image Stretch="Uniform"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             RenderOptions.BitmapScalingMode="HighQuality"
                             Source="{Binding PreviewBefore}" />
                    </Border>
                  </DockPanel>
                  <DockPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Stretch">
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,4"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.TextBody}"
                               Text="После" />
                    <Border BorderBrush="{DynamicResource Theme.CardBorder}"
                            BorderThickness="1"
                            Background="{DynamicResource Theme.PreviewSurface}"
                            CornerRadius="1"
                            VerticalAlignment="Stretch"
                            MinHeight="120">
                      <Image Stretch="Uniform"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             RenderOptions.BitmapScalingMode="HighQuality"
                             Source="{Binding PreviewAfter}" />
                    </Border>
                  </DockPanel>
                </Grid>
              </Grid>
            </GroupBox>
          </Grid>

          <!-- Расширенный режим -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsAdvancedView}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.MinHeight>
              <MultiBinding Converter="{StaticResource PreviewScrollMinHeight}">
                <Binding ElementName="MainScroll" Path="ViewportHeight" />
                <Binding Path="IsPreviewPanelVisible" />
              </MultiBinding>
            </Grid.MinHeight>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="{Binding IsPreviewPanelVisible, Converter={StaticResource BoolToPreviewRowLength}}" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Theme.CardBg}"
                    BorderBrush="{DynamicResource Theme.CardBorder}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="12,10"
                    Margin="0,0,0,8">
              <StackPanel>
                <TextBlock TextWrapping="Wrap"
                           FontSize="11.5"
                           Foreground="{DynamicResource Theme.TextMuted}"
                           LineHeight="16"
                           Text="Для каждого файла — свой референс. Превью совпадает с экспортом. Пути reference и папка Zona (`zona`) по умолчанию из профиля (меню «Профиль»)." />
                <Grid Margin="0,10,0,0"
                      ToolTip="Запуск, пауза и продолжение — одна кнопка. «Отмена» прерывает пакет.">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Button Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          MinWidth="0"
                          Style="{StaticResource PrimaryActionButtonStyle}"
                          Command="{Binding BatchPrimaryClickCommand}"
                          Content="{Binding BatchPrimaryButtonText}" />
                  <Button Grid.Column="2"
                          Style="{StaticResource CancelBatchButtonStyle}"
                          Command="{Binding CancelBatchCommand}"
                          Content="Отмена"
                          ToolTip="Прервать кадрирование" />
                </Grid>
                <Grid Margin="0,10,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             VerticalAlignment="Center"
                             Margin="0,0,12,0"
                             FontSize="11"
                             Foreground="{DynamicResource Theme.TextSubtle}"
                             TextWrapping="Wrap"
                             Text="Анализ (длинная сторона)" />
                  <StackPanel Grid.Column="1">
                    <Slider Minimum="512"
                            Maximum="4096"
                            TickFrequency="64"
                            IsSnapToTickEnabled="True"
                            Value="{Binding AnalysisMaxEdge, Mode=TwoWay}" />
                    <TextBlock Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource Theme.TextHint}"
                               Text="{Binding AnalysisMaxEdge, StringFormat={}{0:0} px}" />
                  </StackPanel>
                </Grid>
                <CheckBox Margin="0,8,0,0"
                          FontSize="12"
                          Content="Сохранять результат в WebP (.webp); снять галочку — JPEG (.jpg)"
                          IsChecked="{Binding SaveAsWebP, Mode=TwoWay}" />
                <StackPanel Margin="0,12,0,0">
                  <TextBlock FontSize="11"
                             Foreground="{DynamicResource Theme.TextHint}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,8"
                             Text="Профиль на диске: %LocalAppData%\AutoRAW\user files\Profile (reference, zona для технологии Zona, setting). Черновик — «Несохранённые изменения»." />
                  <Button Margin="0,0,0,6"
                          HorizontalAlignment="Stretch"
                          Padding="10,6"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Content="Применить к исходному профилю…"
                          Command="{Binding CommitDraftApplyCommand}" />
                  <Button HorizontalAlignment="Stretch"
                          Padding="10,6"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Content="Сохранить как новый профиль…"
                          Command="{Binding CommitDraftNewCommand}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <GroupBox Grid.Row="1" Header="Референс">
              <StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" Text="Папка" />
                  <TextBox Grid.Column="1" Margin="8,0" Height="26" VerticalContentAlignment="Center"
                           Text="{Binding ReferenceFolder, UpdateSourceTrigger=PropertyChanged}" />
                  <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}"
                          Command="{Binding BrowseReferenceFolderCommand}" Content="Обзор…" />
                </Grid>
                <TextBlock Margin="0,8,0,4" VerticalAlignment="Center" FontSize="12" TextWrapping="Wrap" Text="По умолчанию" />
                <ComboBox MinWidth="0"
                          Margin="0,0,0,6"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding ReferenceFiles}"
                          SelectedItem="{Binding SelectedReferenceFile, Mode=TwoWay}"
                          IsEditable="False"
                          ToolTip="Подставляется в строки таблицы ниже." />
                <Button HorizontalAlignment="Stretch"
                        Padding="10,5"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ApplyDefaultReferenceToAllCommand}"
                        Content="На все строки" />
              </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="Вход, выход и Zona">
              <StackPanel>
                <TextBlock FontSize="12" Foreground="{DynamicResource Theme.TextBody}" Text="Вход" />
                <TextBlock Margin="0,2,0,4"
                           FontSize="10.5"
                           Foreground="{DynamicResource Theme.TextHint}"
                           Text="Обзор… или перетащите папку / файлы сюда" />
                <Border Tag="InputDropZone"
                        Padding="8,8"
                        Margin="0,0,0,2"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource Theme.CardBorder}"
                        Background="Transparent">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Margin="0,0,8,0"
                             Height="26"
                             VerticalContentAlignment="Center"
                             Text="{Binding InputFolder, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseInputFolderCommand}"
                            Content="Обзор…" />
                  </Grid>
                </Border>
                <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="{DynamicResource Theme.TextBody}" Text="Выход" />
                <Grid Margin="0,4,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0" Margin="0,0,8,0" Height="26" VerticalContentAlignment="Center"
                           Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Пусто — вход\webp|jpg\подпапка\. Задана — выход\подпапка\." />
                  <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                          Command="{Binding BrowseOutputFolderCommand}" Content="Обзор…" />
                </Grid>
                <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="{DynamicResource Theme.TextBody}"
                           Text="Zona (маркёры)"
                           ToolTip="Технология Zona: папка `zona` с изображениями-маркёрами; красная зона задаёт кроп на парном исходнике. Собственная разработка для AutoRAW." />
                <Grid Margin="0,4,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0" Margin="0,0,8,0" Height="26" VerticalContentAlignment="Center"
                           Text="{Binding ZonaFolder, UpdateSourceTrigger=PropertyChanged}" />
                  <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                          Command="{Binding BrowseZonaFolderCommand}" Content="Обзор…" />
                </Grid>
              </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="3"
                      Header="Цветовой профиль"
                      Visibility="{Binding IsColorProfilePanelVisible, Converter={StaticResource BoolToVis}}">
              <StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Theme.TextMuted}" Text="{Binding ColorSpaceSummaryText, Mode=OneWay}" />
                <TextBlock Margin="0,2,0,6" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource Theme.TextHint}" Text="{Binding ColorNumericSummary, Mode=OneWay}" />
                <CheckBox FontSize="12"
                          Content="Применить коррекцию цвета (альфа)"
                          IsChecked="{Binding ApplyColorCorrection, Mode=TwoWay}"
                          ToolTip="Включение требует подтверждения. При смене профиля сбрасывается." />
                <Button Margin="0,8,0,0" HorizontalAlignment="Stretch" Padding="10,5" Style="{StaticResource SecondaryButtonStyle}"
                        Content="Настроить профиль…"
                        Command="{Binding EditColorProfileCommand}" />
              </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="4" Header="Файлы и референсы">
              <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,6"
                           FontSize="11"
                           Foreground="{DynamicResource Theme.TextHint}"
                           TextWrapping="Wrap"
                           Text="Список из папки входа. Для каждой строки выберите референс (кадр и отступы от объекта)." />
                <ListBox ItemsSource="{Binding MappingRows}"
                         MinHeight="120"
                         MaxHeight="220"
                         SelectedItem="{Binding SelectedMappingRow, Mode=TwoWay}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         BorderThickness="0"
                         Background="Transparent">
                  <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CropMappingRowViewModel}">
                      <StackPanel Margin="0,3">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding InputPath}"
                                   Text="{Binding InputFileName}" />
                        <ComboBox Margin="0,6,0,0"
                                  VerticalAlignment="Center"
                                  FontSize="12"
                                  ItemsSource="{Binding DataContext.ReferenceFiles, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding SelectedReferenceFile, Mode=TwoWay}" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </DockPanel>
            </GroupBox>

            <GroupBox Grid.Row="5"
                      Header="Превью: референс · до · после"
                      VerticalAlignment="Stretch"
                      Visibility="{Binding IsPreviewPanelVisible, Converter={StaticResource BoolToVis}}">
              <Grid VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsPreviewLoading, Converter={StaticResource BoolToVis}}">
                  <TextBlock FontSize="11.5"
                             Foreground="{DynamicResource Theme.TextMuted}"
                             TextWrapping="Wrap"
                             Text="{Binding PreviewStatusText, Mode=OneWay}" />
                  <ProgressBar Style="{StaticResource PreviewLoadProgressStyle}" />
                </StackPanel>
                <DockPanel Grid.Row="1" Margin="0,0,0,6" VerticalAlignment="Stretch">
                  <TextBlock DockPanel.Dock="Top"
                             Margin="0,0,0,4"
                             FontSize="11"
                             FontWeight="SemiBold"
                             Text="Референс / технология Zona" />
                  <Border BorderBrush="{DynamicResource Theme.CardBorder}"
                          BorderThickness="1"
                          Background="{DynamicResource Theme.PreviewSurface}"
                          CornerRadius="1"
                          VerticalAlignment="Stretch"
                          MinHeight="80">
                    <Image Stretch="Uniform"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding PreviewReference}" />
                  </Border>
                </DockPanel>
                <DockPanel Grid.Row="2" Margin="0,0,0,6" VerticalAlignment="Stretch">
                  <TextBlock DockPanel.Dock="Top"
                             Margin="0,0,0,4"
                             FontSize="11"
                             FontWeight="SemiBold"
                             Text="До" />
                  <Border BorderBrush="{DynamicResource Theme.CardBorder}"
                          BorderThickness="1"
                          Background="{DynamicResource Theme.PreviewSurface}"
                          CornerRadius="1"
                          VerticalAlignment="Stretch"
                          MinHeight="80">
                    <Image Stretch="Uniform"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding PreviewBefore}" />
                  </Border>
                </DockPanel>
                <DockPanel Grid.Row="3" VerticalAlignment="Stretch">
                  <TextBlock DockPanel.Dock="Top"
                             Margin="0,0,0,4"
                             FontSize="11"
                             FontWeight="SemiBold"
                             Text="После" />
                  <Border BorderBrush="{DynamicResource Theme.CardBorder}"
                          BorderThickness="1"
                          Background="{DynamicResource Theme.PreviewSurface}"
                          CornerRadius="1"
                          VerticalAlignment="Stretch"
                          MinHeight="80">
                    <Image Stretch="Uniform"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding PreviewAfter}" />
                  </Border>
                </DockPanel>
              </Grid>
            </GroupBox>
          </Grid>
        </Grid>
      </ScrollViewer>

      <Grid Grid.Row="1"
            Margin="0,0,0,6"
            Height="22"
            ToolTip="Прогресс кадрирования: обработано/всего. Пауза — «На паузе». По завершении — «Готово N/N»."
            Visibility="{Binding IsBatchStatusVisible, Converter={StaticResource BoolToVis}}">
        <ProgressBar Minimum="0"
                     Maximum="{Binding BatchProgressMaximum}"
                     Value="{Binding BatchProgressValue}"
                     Height="22"
                     Foreground="{DynamicResource Theme.Accent}"
                     Background="{DynamicResource Theme.ProgressTrack}" />
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Theme.TextPrimary}"
                   IsHitTestVisible="False"
                   Text="{Binding BatchStatusText}" />
      </Grid>

      <GroupBox Grid.Row="2"
                Padding="6,6"
                Visibility="{Binding IsLogDockedVisible, Converter={StaticResource BoolToVis}}">
        <GroupBox.Header>
          <DockPanel x:Name="LogGroupBoxHeaderDock"
                     LastChildFill="True"
                     MouseLeftButtonDown="LogHeader_OnMouseLeftButtonDown"
                     MouseMove="LogHeader_OnMouseMove"
                     MouseLeftButtonUp="LogHeader_OnMouseLeftButtonUp">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
              <Button Width="26"
                      Height="22"
                      Margin="4,0,0,0"
                      ToolTip="Отдельное окно: без системной шапки, перетаскивание за заголовок. Повторное нажатие — вернуть сюда."
                      Style="{StaticResource LogToolButtonStyle}"
                      Command="{Binding ToggleLogDetachCommand}"
                      Content="⧉" />
              <Button Width="26"
                      Height="22"
                      Margin="4,0,0,0"
                      ToolTip="Скрыть журнал (Вид → Окна → Показать журнал)"
                      Style="{StaticResource LogToolButtonStyle}"
                      Command="{Binding CloseLogPanelCommand}"
                      Content="✕" />
            </StackPanel>
            <TextBlock VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Cursor="SizeAll"
                       ToolTip="Потянуть, чтобы открыть чат в отдельном окне"
                       Text="Чат Zona" />
          </DockPanel>
        </GroupBox.Header>
        <ListBox x:Name="LogListBox"
                 Style="{StaticResource ZonaChatListBoxStyle}"
                 ItemsSource="{Binding LogLines}"
                 MinHeight="120"
                 MaxHeight="340" />
      </GroupBox>
    </Grid>
  </DockPanel>
</Window>
