<Window x:Class="AutoRAW.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AutoRAW.ViewModels"
        mc:Ignorable="d"
        Title="AutoRAW"
        Icon="Assets/favicon.ico"
        Height="680"
        Width="900"
        MinHeight="520"
        MinWidth="700"
        Background="#F2F3F5"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <Style x:Key="BusyProgressStyle" TargetType="ProgressBar">
      <Setter Property="Height" Value="4" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Foreground" Value="#0F6CBD" />
      <Setter Property="Visibility" Value="Collapsed" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsBusy}" Value="True">
          <Setter Property="Visibility" Value="Visible" />
          <Setter Property="IsIndeterminate" Value="True" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="PreviewLoadProgressStyle" TargetType="ProgressBar">
      <Setter Property="Height" Value="4" />
      <Setter Property="Margin" Value="0,4,0,0" />
      <Setter Property="Foreground" Value="#0F6CBD" />
      <Setter Property="Background" Value="#E2E4E8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Visibility" Value="Collapsed" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsPreviewLoading}" Value="True">
          <Setter Property="Visibility" Value="Visible" />
          <Setter Property="IsIndeterminate" Value="True" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#0F6CBD" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Style.Triggers>
        <MultiTrigger>
          <MultiTrigger.Conditions>
            <Condition Property="IsMouseOver" Value="True" />
            <Condition Property="IsEnabled" Value="True" />
          </MultiTrigger.Conditions>
          <Setter Property="Background" Value="#39940e" />
        </MultiTrigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Background" Value="#E4E4E4" />
          <Setter Property="Foreground" Value="#555555" />
          <Setter Property="BorderBrush" Value="#B0B0B0" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="Cursor" Value="Arrow" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="88" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#C8C8C8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="GroupBox">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="BorderBrush" Value="#D8DADC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>
  </Window.Resources>

  <DockPanel Background="#F2F3F5">
    <Border DockPanel.Dock="Top" Background="White" BorderBrush="#D8DADC" BorderThickness="0,0,0,1">
      <Menu Background="Transparent" Padding="4,2">
        <MenuItem x:Name="MenuProfileRoot"
                  Header="Профиль"
                  SubmenuOpened="ProductSubmenu_OnSubmenuOpened"
                  Loaded="MenuProfileRoot_OnLoaded" />
        <MenuItem Header="Вид">
          <MenuItem Header="Показать журнал"
                    IsCheckable="True"
                    StaysOpenOnClick="True"
                    IsChecked="{Binding IsLogPanelVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          <MenuItem Header="Расширенный режим"
                    IsCheckable="True"
                    StaysOpenOnClick="True"
                    IsChecked="{Binding IsAdvancedView, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </MenuItem>
        <MenuItem Header="Справка">
          <MenuItem Header="О программе…" Command="{Binding ShowAboutCommand}" />
          <MenuItem Header="Инструкция" Command="{Binding ShowInstructionCommand}" />
          <MenuItem Header="Чендж лог" Command="{Binding ShowChangelogCommand}" />
        </MenuItem>
      </Menu>
    </Border>

    <Grid Margin="14,12,14,12">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <ScrollViewer Grid.Row="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Padding="0,0,4,0">
        <Grid>
          <!-- Простой режим -->
          <StackPanel>
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsAdvancedView}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>

            <!-- Шапка: профиль + главное действие -->
            <Border Background="White"
                    BorderBrush="#D8DADC"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="12,10"
                    Margin="0,0,0,8">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                  <TextBlock FontSize="13" Foreground="#1A1A1A">
                    <Run Text="Профиль: " />
                    <Run Text="{Binding SelectedProduct.DisplayName, Mode=OneWay}" FontWeight="SemiBold" />
                  </TextBlock>
                  <TextBlock Margin="0,4,0,0"
                             TextWrapping="Wrap"
                             FontSize="11.5"
                             Foreground="#5C5C5C"
                             LineHeight="16"
                             Text="Папки reference и zona задаёт выбранный профиль (меню «Профиль»). Смените профиль, если нужен другой тип товара." />
                </StackPanel>
                <Button Grid.Row="0"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0"
                        MinWidth="200"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Command="{Binding RunBatchCommand}"
                        Content="Запустить кадрирование" />
                <CheckBox Grid.Row="1"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          Margin="0,10,0,0"
                          FontSize="12"
                          Content="Сохранять результат в WebP (.webp); снять галочку — JPEG (.jpg)"
                          IsChecked="{Binding SaveAsWebP, Mode=TwoWay}" />
              </Grid>
            </Border>

            <GroupBox Header="Папки">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="108" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#333" Text="Товар (вход)" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="8,0,8,0"
                         Height="26"
                         VerticalContentAlignment="Center"
                         Text="{Binding InputFolder, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseInputFolderCommand}"
                        Content="Обзор…" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" FontSize="12" Foreground="#333" Text="Выход" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="8,8,8,0"
                         Height="26"
                         VerticalContentAlignment="Center"
                         Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Пусто — для каждого файла: подпапка «webp» или «jpg» в каталоге исходника, имя файла то же (.webp / .jpg). Если папка выхода задана — все файлы туда." />
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,8,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseOutputFolderCommand}"
                        Content="Обзор…" />
              </Grid>
            </GroupBox>

            <GroupBox Header="Цветовой профиль">
              <StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#444" Text="{Binding ColorSpaceSummaryText, Mode=OneWay}" />
                <TextBlock Margin="0,2,0,6" TextWrapping="Wrap" FontSize="11" Foreground="#666" Text="{Binding ColorNumericSummary, Mode=OneWay}" />
                <StackPanel Orientation="Horizontal">
                  <CheckBox VerticalAlignment="Center"
                            FontSize="12"
                            Content="Применить коррекцию цвета (альфа)"
                            IsChecked="{Binding ApplyColorCorrection, Mode=TwoWay}"
                            ToolTip="Включение требует подтверждения. При смене профиля сбрасывается." />
                  <Button Margin="14,0,0,0"
                          Padding="10,5"
                          VerticalAlignment="Center"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Content="Настроить профиль…"
                          Command="{Binding EditColorProfileCommand}" />
                </StackPanel>
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Превью">
              <StackPanel>
                <StackPanel Margin="0,0,0,8" Visibility="{Binding IsPreviewLoading, Converter={StaticResource BoolToVis}}">
                  <TextBlock FontSize="11.5"
                             Foreground="#444"
                             TextWrapping="Wrap"
                             Text="{Binding PreviewStatusText, Mode=OneWay}" />
                  <ProgressBar Style="{StaticResource PreviewLoadProgressStyle}" />
                </StackPanel>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             VerticalAlignment="Center"
                             Margin="0,0,12,0"
                             FontSize="11"
                             Foreground="#555"
                             TextWrapping="Wrap"
                             Text="Анализ (длинная сторона)" />
                  <StackPanel Grid.Column="1">
                    <Slider Minimum="512"
                            Maximum="4096"
                            TickFrequency="64"
                            IsSnapToTickEnabled="True"
                            Value="{Binding AnalysisMaxEdge, Mode=TwoWay}" />
                    <TextBlock Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="#666"
                               Text="{Binding AnalysisMaxEdge, StringFormat={}{0:0} px}" />
                  </StackPanel>
                </Grid>
                <UniformGrid Rows="1" Columns="2">
                <StackPanel Margin="2,0,6,0">
                  <TextBlock Margin="0,0,0,4" FontSize="12" FontWeight="SemiBold" Foreground="#333" Text="До" />
                  <Border BorderBrush="#D8DADC" BorderThickness="1" Background="#FAFAFA" CornerRadius="1">
                    <Image MaxHeight="160"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding PreviewBefore}" />
                  </Border>
                </StackPanel>
                <StackPanel Margin="6,0,2,0">
                  <TextBlock Margin="0,0,0,4" FontSize="12" FontWeight="SemiBold" Foreground="#333" Text="После" />
                  <Border BorderBrush="#D8DADC" BorderThickness="1" Background="#FAFAFA" CornerRadius="1">
                    <Image MaxHeight="160"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding PreviewAfter}" />
                  </Border>
                </StackPanel>
              </UniformGrid>
              </StackPanel>
            </GroupBox>
          </StackPanel>

          <!-- Расширенный режим -->
          <StackPanel>
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsAdvancedView}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>

            <Border Background="White"
                    BorderBrush="#D8DADC"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="12,10"
                    Margin="0,0,0,8">
              <StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             TextWrapping="Wrap"
                             FontSize="11.5"
                             Foreground="#444"
                             LineHeight="16"
                             Text="Для каждого файла — свой референс. Превью совпадает с экспортом. Пути reference и zona по умолчанию из профиля (меню «Профиль»)." />
                  <Button Grid.Column="1"
                          Margin="12,0,0,0"
                          VerticalAlignment="Top"
                          MinWidth="200"
                          Style="{StaticResource PrimaryActionButtonStyle}"
                          Command="{Binding RunBatchCommand}"
                          Content="Запустить кадрирование" />
                </Grid>
                <Grid Margin="0,10,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             VerticalAlignment="Center"
                             Margin="0,0,12,0"
                             FontSize="11"
                             Foreground="#555"
                             Text="Анализ (длинная сторона)" />
                  <StackPanel Grid.Column="1">
                    <Slider Minimum="512"
                            Maximum="4096"
                            TickFrequency="64"
                            IsSnapToTickEnabled="True"
                            Value="{Binding AnalysisMaxEdge, Mode=TwoWay}" />
                    <TextBlock Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="#666"
                               Text="{Binding AnalysisMaxEdge, StringFormat={}{0:0} px}" />
                  </StackPanel>
                </Grid>
                <CheckBox Margin="0,8,0,0"
                          FontSize="12"
                          Content="Сохранять результат в WebP (.webp); снять галочку — JPEG (.jpg)"
                          IsChecked="{Binding SaveAsWebP, Mode=TwoWay}" />
                <StackPanel Margin="0,12,0,0" Orientation="Vertical">
                  <TextBlock FontSize="11"
                             Foreground="#666"
                             TextWrapping="Wrap"
                             Margin="0,0,0,8"
                             Text="Профиль на диске: %LocalAppData%\AutoRAW\user files\Profile (reference, zona, setting). Черновик — «Несохранённые изменения»." />
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Margin="0,0,8,0"
                            Padding="10,6"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Применить к исходному профилю…"
                            Command="{Binding CommitDraftApplyCommand}" />
                    <Button Padding="10,6"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Сохранить как новый профиль…"
                            Command="{Binding CommitDraftNewCommand}" />
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>

            <GroupBox Header="Референс">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Text="Папка" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0" Height="26" VerticalContentAlignment="Center"
                         Text="{Binding ReferenceFolder, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseReferenceFolderCommand}" Content="Обзор…" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" VerticalAlignment="Center" FontSize="12" TextWrapping="Wrap" Text="По умолчанию" />
                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,6,0,0" Orientation="Horizontal">
                  <ComboBox MinWidth="200"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ItemsSource="{Binding ReferenceFiles}"
                            SelectedItem="{Binding SelectedReferenceFile, Mode=TwoWay}"
                            IsEditable="False"
                            ToolTip="Подставляется в строки таблицы ниже." />
                  <Button VerticalAlignment="Center" Padding="10,5" Style="{StaticResource SecondaryButtonStyle}"
                          Command="{Binding ApplyDefaultReferenceToAllCommand}"
                          Content="На все строки" />
                </StackPanel>
              </Grid>
            </GroupBox>

            <GroupBox Header="Вход, выход и zona">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Text="Вход" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0" Height="26" VerticalContentAlignment="Center"
                         Text="{Binding InputFolder, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseInputFolderCommand}" Content="Обзор…" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" VerticalAlignment="Center" FontSize="12" Text="Выход" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="8,6,8,0" Height="26" VerticalContentAlignment="Center"
                         Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Пусто — для каждого файла: подпапка «webp» или «jpg» в каталоге исходника. Если задана папка выхода — все файлы туда (галочка WebP в шапке)." />
                <Button Grid.Row="1" Grid.Column="2" Margin="0,6,0,0" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseOutputFolderCommand}" Content="Обзор…" />

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" VerticalAlignment="Center" FontSize="12"
                           Text="Zona" ToolTip="Красная рамка на jpg — зона кропа для соответствующего .nef" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="8,6,8,0" Height="26" VerticalContentAlignment="Center"
                         Text="{Binding ZonaFolder, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="2" Grid.Column="2" Margin="0,6,0,0" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseZonaFolderCommand}" Content="Обзор…" />
              </Grid>
            </GroupBox>

            <GroupBox Header="Цветовой профиль">
              <StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#444" Text="{Binding ColorSpaceSummaryText, Mode=OneWay}" />
                <TextBlock Margin="0,2,0,6" TextWrapping="Wrap" FontSize="11" Foreground="#666" Text="{Binding ColorNumericSummary, Mode=OneWay}" />
                <StackPanel Orientation="Horizontal">
                  <CheckBox VerticalAlignment="Center"
                            FontSize="12"
                            Content="Применить коррекцию цвета (альфа)"
                            IsChecked="{Binding ApplyColorCorrection, Mode=TwoWay}"
                            ToolTip="Включение требует подтверждения. При смене профиля сбрасывается." />
                  <Button Margin="14,0,0,0" Padding="10,5" VerticalAlignment="Center" Style="{StaticResource SecondaryButtonStyle}"
                          Content="Настроить профиль…"
                          Command="{Binding EditColorProfileCommand}" />
                </StackPanel>
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Файлы и референсы">
              <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,6"
                           FontSize="11"
                           Foreground="#666"
                           TextWrapping="Wrap"
                           Text="Список из папки входа. Для каждой строки выберите референс (кадр и отступы от объекта)." />
                <ListBox ItemsSource="{Binding MappingRows}"
                         MinHeight="120"
                         MaxHeight="220"
                         SelectedItem="{Binding SelectedMappingRow, Mode=TwoWay}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         BorderThickness="0"
                         Background="Transparent">
                  <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CropMappingRowViewModel}">
                      <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding InputPath}"
                                   Text="{Binding InputFileName}" />
                        <ComboBox Grid.Column="1"
                                  Margin="10,0,0,0"
                                  VerticalAlignment="Center"
                                  FontSize="12"
                                  ItemsSource="{Binding DataContext.ReferenceFiles, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding SelectedReferenceFile, Mode=TwoWay}" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </DockPanel>
            </GroupBox>

            <GroupBox Header="Превью: референс · до · после">
              <StackPanel>
                <StackPanel Margin="0,0,0,8" Visibility="{Binding IsPreviewLoading, Converter={StaticResource BoolToVis}}">
                  <TextBlock FontSize="11.5"
                             Foreground="#444"
                             TextWrapping="Wrap"
                             Text="{Binding PreviewStatusText, Mode=OneWay}" />
                  <ProgressBar Style="{StaticResource PreviewLoadProgressStyle}" />
                </StackPanel>
                <UniformGrid Rows="1" Columns="3">
                <StackPanel Margin="2,0,4,0">
                  <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Text="Референс / Zona" />
                  <Border BorderBrush="#D8DADC" BorderThickness="1" Background="#FAFAFA" CornerRadius="1">
                    <Image MaxHeight="180"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding PreviewReference}" />
                  </Border>
                </StackPanel>
                <StackPanel Margin="4,0,4,0">
                  <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Text="До" />
                  <Border BorderBrush="#D8DADC" BorderThickness="1" Background="#FAFAFA" CornerRadius="1">
                    <Image MaxHeight="180"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding PreviewBefore}" />
                  </Border>
                </StackPanel>
                <StackPanel Margin="4,0,2,0">
                  <TextBlock Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Text="После" />
                  <Border BorderBrush="#D8DADC" BorderThickness="1" Background="#FAFAFA" CornerRadius="1">
                    <Image MaxHeight="180"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding PreviewAfter}" />
                  </Border>
                </StackPanel>
              </UniformGrid>
              </StackPanel>
            </GroupBox>
          </StackPanel>
        </Grid>
      </ScrollViewer>

      <ProgressBar Grid.Row="1" Style="{StaticResource BusyProgressStyle}" />

      <GroupBox Grid.Row="2"
                Header="Журнал"
                Padding="6,6"
                Visibility="{Binding IsLogPanelVisible, Converter={StaticResource BoolToVis}}">
        <ListBox ItemsSource="{Binding LogLines}"
                 FontFamily="Consolas"
                 FontSize="11"
                 MinHeight="100"
                 MaxHeight="200"
                 Background="#FAFAFA"
                 BorderBrush="#D8DADC"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
      </GroupBox>
    </Grid>
  </DockPanel>
</Window>
