<Window x:Class="AutoRAW.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoRAW"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Width="800"
        Height="350"
        Background="Black"
        SnapsToDevicePixels="True">

  <Grid ClipToBounds="True">
    <Image x:Name="SplashImage"
           Stretch="UniformToFill"
           HorizontalAlignment="Stretch"
           VerticalAlignment="Stretch"
           Source="pack://application:,,,/Assets/SplashScreen.png" />

    <!-- Версия: справа вверху, только цифры Major.Minor.Build -->
    <TextBlock x:Name="VersionLine"
               HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Margin="0,17,21,0"
               FontSize="13"
               FontWeight="SemiBold"
               Foreground="#0F172A"
               Text="Версия" />

    <!-- Низ: статус с анимированной полосой, слева -->
    <Grid VerticalAlignment="Bottom"
          HorizontalAlignment="Stretch"
          Margin="19,0,19,21">
      <Border x:Name="StatusChrome"
              HorizontalAlignment="Left"
              MinWidth="180"
              MaxWidth="720"
              VerticalAlignment="Center"
              Background="#CC0F172A"
              BorderBrush="#33FFFFFF"
              BorderThickness="1"
              CornerRadius="4"
              Padding="11,9">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock x:Name="StatusBarText"
                     Grid.Row="0"
                     FontSize="12"
                     Foreground="#F1F5F9"
                     TextWrapping="Wrap"
                     Text="Загрузка интерфейса…" />
          <ProgressBar x:Name="StatusProgressBar"
                       Grid.Row="2"
                       Height="3"
                       BorderThickness="0"
                       Background="#334155"
                       Foreground="#0F6CBD"
                       IsIndeterminate="True"
                       IsHitTestVisible="False" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
